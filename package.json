{
  "name": "guardalo",
  "version": "10.0.0",
  "description": "GUARDALO — guida interattiva a livelli per anime. Dati reali da AniList, hosting statico gratuito.",
  "type": "module",
  "private": true,
  "scripts": {
    "map": "node tools/build.mjs map",
    "fetch": "node tools/build.mjs fetch",
    "gen": "node tools/build.mjs gen",
    "build": "node tools/build.mjs all",
    "prerender": "node tools/prerender.mjs",
    "build:site": "node tools/build.mjs gen && node tools/prerender.mjs",
    "report": "node tools/build.mjs report",
    "serve": "node tools/serve.mjs"
  }
}
